# ── Database ──────────────────────────────────────────────────────────────────
# SQLite is used by default (see database.py). Postgres vars below are for
# future migration; leave them as-is unless you've switched the engine.
POSTGRES_HOST=localhost
POSTGRES_PORT=5432
POSTGRES_DB=research_dataset_builder
POSTGRES_USER=postgres
POSTGRES_PASSWORD=postgres

DUCKDB_PATH=./data/warehouse.duckdb

# ── Authentication ────────────────────────────────────────────────────────────
# IMPORTANT: run setup.sh — it generates a secure random key automatically.
# Never use the default placeholder in production.
JWT_SECRET_KEY=dev-secret-key-change-in-production-12345678901234567890
JWT_ALGORITHM=HS256
JWT_ACCESS_TOKEN_EXPIRE_MINUTES=30

# ── CORS ──────────────────────────────────────────────────────────────────────
# Comma-separated list of allowed frontend origins.
CORS_ORIGINS=http://localhost:3000,http://localhost:3001

# ── LLM (optional) ───────────────────────────────────────────────────────────
# Leave commented out to use demo/pattern-matching mode.
# OPENAI_API_KEY=sk-...
# ANTHROPIC_API_KEY=sk-ant-...
LLM_PROVIDER=openai

# ── FHIR (optional) ──────────────────────────────────────────────────────────
# FHIR_BASE_URL=https://fhir.example.com/api/FHIR/R4
# FHIR_AUTH_TOKEN=your-fhir-token

# ── Application ───────────────────────────────────────────────────────────────
APP_ENV=development
LOG_LEVEL=INFO
